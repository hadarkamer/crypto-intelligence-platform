# Required by Render / Telegram
TELEGRAM_BOT_TOKEN=
PUBLIC_URL=https://your-service.onrender.com
DATABASE_URL=
PORT=10000
PYTHON_VERSION=3.11.9

# CoinGlass live scanner
COINGLASS_MAX_PAIN_URL=https://www.coinglass.com/liquidation-maxpain
MAX_SECONDS_PER_TIMEFRAME=120
RETRY_SLEEP_SECONDS=4

# Binance USD-M Futures mark price only
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
BINANCE_FUTURES_MARK_ENDPOINT=/fapi/v1/premiumIndex
BINANCE_PRICE_TIMEOUT_SECONDS=15

# Live alert Watch
WATCH_INTERVAL_MINUTES=15
WATCH_PRIORITY_THRESHOLD=70
WATCH_COOLDOWN_MINUTES=60
MIN_DISPLAY_DISTANCE_PCT=0.5

# TradingView / Rai indicator ingestion
# Optional. When empty, TradingView requests are accepted without a secret.
TRADINGVIEW_WEBHOOK_SECRET=
